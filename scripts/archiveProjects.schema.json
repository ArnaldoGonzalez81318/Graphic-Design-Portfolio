{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laurarivera.design/schemas/archiveProjects.schema.json",
  "title": "Archive Projects Seed Schema",
  "description": "Portfolio archive items consumed by the archive gallery and project detail routes.",
  "collection": "archiveProjects",
  "documentId": "slug",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "slug",
      "sortOrder",
      "title",
      "client",
      "year",
      "category",
      "format",
      "summary",
      "headline",
      "overview",
      "challenge",
      "approach",
      "outcome",
      "palette",
      "tags",
      "services",
      "deliverables",
      "metrics",
      "mockup",
      "featured"
    ],
    "properties": {
      "slug": {
        "type": "string",
        "minLength": 3,
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "sortOrder": {
        "type": "integer",
        "minimum": 1
      },
      "title": {
        "type": "string",
        "minLength": 2
      },
      "client": {
        "type": "string",
        "minLength": 2
      },
      "year": {
        "type": "string",
        "pattern": "^[0-9]{4}$"
      },
      "category": {
        "type": "string",
        "minLength": 2
      },
      "format": {
        "type": "string",
        "minLength": 2
      },
      "summary": {
        "type": "string",
        "minLength": 10
      },
      "headline": {
        "type": "string",
        "minLength": 10
      },
      "overview": {
        "type": "string",
        "minLength": 20
      },
      "challenge": {
        "type": "string",
        "minLength": 20
      },
      "approach": {
        "type": "string",
        "minLength": 20
      },
      "outcome": {
        "type": "string",
        "minLength": 20
      },
      "palette": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "prefixItems": [
          {
            "$ref": "#/$defs/hexColor"
          },
          {
            "$ref": "#/$defs/hexColor"
          },
          {
            "$ref": "#/$defs/hexColor"
          }
        ]
      },
      "tags": {
        "$ref": "#/$defs/nonEmptyStringArray"
      },
      "services": {
        "$ref": "#/$defs/nonEmptyStringArray"
      },
      "deliverables": {
        "$ref": "#/$defs/nonEmptyStringArray"
      },
      "metrics": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "label",
            "value"
          ],
          "properties": {
            "label": {
              "type": "string",
              "minLength": 2
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "mockup": {
        "type": "string",
        "enum": [
          "packaging",
          "campaign",
          "festival",
          "editorial",
          "product",
          "stage",
          "hospitality"
        ]
      },
      "featured": {
        "type": "boolean"
      }
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}